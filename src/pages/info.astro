---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="boyoung — info" currentPath="/info">
	<div class="mx-auto max-w-6xl px-5 pb-24 pt-2 md:px-10 md:pt-4">
		<div class="grid gap-12 md:grid-cols-12 md:gap-10 lg:gap-14">
			<div class="md:col-span-7 lg:col-span-8">
				<section class="mb-12 md:mb-16">
					
					<div
						class="font-serif text-[0.98rem] leading-[1.65] text-ink/90 md:text-[1.02rem]"
					>
						<p>
							intro in eng
						</p>
						<p class="mt-4">
							intro in eng
						</p>
					</div>
				</section>

				<section>
					
					<div
						class="font-serif text-[0.98rem] leading-[1.75] text-ink/90 md:text-[1.02rem] [&_p+p]:mt-4"
					>
						<p>
							한국말 소개
						</p>
						<p>
							한국말 소개
						</p>
					</div>
				</section>
			</div>

			<aside class="flex flex-col gap-10 md:col-span-5 lg:col-span-4">
				<div>
					<h2 class="sr-only">contact</h2>
					<ul
						class="space-y-3 font-sans text-sm font-medium lowercase tracking-[var(--tracking-sans)] text-ink"
					>
						<li>
							<a href="mailto:hello@example.com" class="text-ink no-underline hover:opacity-70">
								studio@mediumofcases.com
							</a>
						</li>
						<li>
							<a
								href="https://www.instagram.com/mediumofcases/"
								class="text-ink no-underline hover:opacity-70"
								target="_blank"
								rel="noopener noreferrer"
							>
								instagram
							</a>
						</li>
					</ul>
				</div>

				<div class="mt-auto">
					<div
						class="aspect-square max-w-sm overflow-hidden rounded-sm border border-black/5 bg-white"
					>
						<img
							src="/info-feature.svg"
							alt=""
							class="h-full w-full object-cover"
							width="400"
							height="400"
							loading="lazy"
						/>
					</div>
				</div>
			</aside>
		</div>
	</div>
</BaseLayout>
