---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import { marked } from "marked";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomePortfolio from "../components/react/HomePortfolio";

const raw = await getCollection("work");
const sorted = [...raw].sort(
	(a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);

const works = await Promise.all(
	sorted.map(async (entry) => {
		const img = await getImage({ src: entry.data.thumbnail, width: 1200 });
		const body = entry.body ?? "";
		const bodyHtml = marked(body, { async: false });
		return {
			id: entry.id,
			title: entry.data.title,
			thumbSrc: img.src,
			thumbWidth: Number(img.attributes.width ?? 800),
			thumbHeight: Number(img.attributes.height ?? 1000),
			bodyHtml,
		};
	}),
);

const stickerSrcs = works.map((w) => w.thumbSrc);
---

<BaseLayout title="boyoung" currentPath="/">
	<HomePortfolio client:load works={works} stickerSrcs={stickerSrcs} />
</BaseLayout>
